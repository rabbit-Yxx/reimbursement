{
  "name": "reimbursement-tool",
  "productName": "报销材料整理工具",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "build:electron": "node build-electron.mjs",
    "dev": "concurrently -k -n \"Vite,Electron\" -c \"cyan,yellow\" \"npm run dev:renderer\" \"npm run build:electron && wait-on tcp:5173 && electron .\"",
    "electron:build": "vite build && node build-electron.mjs && electron-builder --win"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "concurrently": "^10.0.3",
    "electron-store": "^11.0.2",
    "exceljs": "^4.4.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "province-city-china": "^8.5.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "sharp": "^0.35.0",
    "tesseract.js": "^7.0.0",
    "wait-on": "^9.0.10",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "build": {
    "appId": "com.company.reimbursement-tool",
    "productName": "报销材料整理工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "报销材料整理工具"
    }
  }
}
